# ===== REQUIRED — change-me values =====
COMPOSE_PROJECT_NAME=opencode-lab
TZ=UTC

N8N_HOST=flow.localhost
N8N_VERSION=2.28.5
N8N_PROTOCOL=http
WEBHOOK_URL=http://flow.localhost:5678/
N8N_EDITOR_BASE_URL=http://flow.localhost:5678/
N8N_PROXY_HOPS=1
GENERIC_TIMEZONE=UTC
N8N_PORT=5678
N8N_CONCURRENCY_PRODUCTION_LIMIT=4
N8N_WORKER_CONCURRENCY=2
N8N_EXECUTIONS_TIMEOUT=604800
N8N_EXECUTIONS_TIMEOUT_MAX=604800
N8N_RUNNERS_HEARTBEAT_INTERVAL=120000

POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-postgres

N8N_ENCRYPTION_KEY=change-me-64-chars-minimum-change-me-64-chars-minimum
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-n8n

OPENCODE_AGENT=build

OPENCODE_WORKER_1_NAME=worker-1
OPENCODE_WORKER_1_PORT=4096
OPENCODE_WORKER_1_PASSWORD=change-me-opencode-worker-1
OPENCODE_WORKER_1_ALIAS=worker-1

OPENCODE_WORKER_1_BASE_URL=http://opencode-worker-1:4096
OPENCODE_WORKER_1_HEALTH_URL=http://opencode-worker-1:4096/global/health

OPENCODE_PROVIDER_TIMEOUT_MS=1800000
OPENCODE_PROVIDER_CHUNK_TIMEOUT_MS=900000
OPENCODE_MCP_TIMEOUT_MS=120000
OPENCODE_WORKER_CPU_LIMIT=2
OPENCODE_WORKER_MEMORY_LIMIT=4g

# ===== REQUIRED for AI — at least one LLM API key =====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# ===== REQUIRED for Telegram — set both =====
TELEGRAM_BOT_TOKEN=
# Comma-separated list of allowed chat IDs: 123456789,987654321,111222333
TELEGRAM_CHAT_IDS=

# ===== REQUIRED for HTTPS via Caddy =====
ENABLE_CADDY_PROXY=false
PUBLIC_N8N_DOMAIN=
ACME_EMAIL=
# HA domain auto-derived as ha.<n8n_host> when ENABLE_CADDY_PROXY=true, or set explicitly:
# PUBLIC_HA_DOMAIN=

# ===== OPTIONAL: Home Assistant voice integration =====
# Create token in HA: Profile → Security → Long-lived access tokens
HA_API_TOKEN=
# Full notification service name for your phone (not just prefix).
# Find it: HA → Developer Tools → Services → search "notify.mobile_app"
# Example: notify.mobile_app_infinix_x6731b
HA_NOTIFY_SERVICE=notify.mobile_app_YOUR_DEVICE
# Language for the voice pipeline (stt, tts, conversation).
# Default: ru. Supported: any language code HA accepts (en, ru, de, fr, etc.)
HA_PIPELINE_LANGUAGE=ru
# Hostname or IP for Home Assistant from n8n's perspective.
# Default: host.docker.internal (works because HA has network_mode: host)
# Change to your server IP/domain if HA runs on a different machine.
# HA_HOST=host.docker.internal

# ===== OPTIONAL: CI/CD (gh CLI uses GITHUB_TOKEN above) =====
# GITHUB_REPOSITORY=
# GITLAB_TOKEN=

# ===== OPTIONAL: database introspection (for /db command) =====
# DATABASE_URL=

# ===== OPTIONAL: MCP server API keys =====
# BRAVE_API_KEY=
