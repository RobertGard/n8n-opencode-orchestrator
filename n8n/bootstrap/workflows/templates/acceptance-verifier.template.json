    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const toText = (v) => String(v ?? '').trim()\n\nlet rawOutput = {}\ntry { rawOutput = $('DeepSeek Judge').first().json } catch (_) {}\nconst content = toText(rawOutput.output ?? rawOutput.text ?? '')\n\nif (!content) {\n  return { json: { verdict: 'FAILED', reason: 'DeepSeek вернул пустой ответ', fixNeeded: true } }\n}\n\nfunction extractJson(text) {\n  const stripped = text.replace(/```(?:json)?/g, '').replace(/```/g, '').trim()\n  try { return JSON.parse(stripped) } catch (_) {}\n  const start = text.indexOf('{')\n  if (start === -1) return null\n  let depth = 0, inString = false, escape = false\n  for (let i = start; i < text.length; i++) {\n    const ch = text[i]\n    if (escape) { escape = false; continue }\n    if (ch === '\\\\') { escape = true; continue }\n    if (ch === '\"') { inString = !inString; continue }\n    if (inString) continue\n    if (ch === '{') depth++\n    if (ch === '}') { depth--; if (depth === 0) { try { return JSON.parse(text.slice(start, i + 1)) } catch (_) { return null } } }\n  }\n  return null\n}\n\nconst parsed = extractJson(content)\nif (!parsed) {\n  const looksPassed = content.toLowerCase().includes('passed') && !content.toLowerCase().includes('failed')\n  return { json: { verdict: looksPassed ? 'PASSED' : 'FAILED', reason: content.slice(0, 300), fixNeeded: !looksPassed } }\n}\n\nconst input = $('Разбираем входные данные').item.json\n\nreturn {\n  json: {\n    verdict: String(parsed.verdict || '').toUpperCase(),\n    reason: String(parsed.reason || ''),\n    fixNeeded: String(parsed.verdict || '').toUpperCase() !== 'PASSED',\n    taskKey: input.taskKey, chatId: input.chatId,\n    originalPrompt: input.originalPrompt,\n    acceptanceCriteria: input.acceptanceCriteria,\n    workerAlias: input.workerAlias,\n    parentTaskKey: input.parentTaskKey || input.taskKey,\n    parentSessionId: input.parentSessionId || input.sessionId,\n    parentOriginalPrompt: input.parentOriginalPrompt || input.originalPrompt,\n    verificationResult: input.resultText,\n  },\n}"
      },
