      "position": [
        940,
        320
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const updated = $input.item.json\nconst found = Number(updated?.count || 0) > 0\nreturn {\n  json: {\n    ok: found,\n    task_key: $('Извлекаем параметры').item.json.task_key,\n    reason: $('Извлекаем параметры').item.json.reason,\n    message: found\n      ? `Задача ${$('Извлекаем параметры').item.json.task_key} отменена`\n      : `Задача ${$('Извлекаем параметры').item.json.task_key} не найдена или уже завершена`,\n  },\n}"
      },
      "id": "build-response",
      "name": "Формируем ответ",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1180,
        320
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "return {\n  json: {\n    ok: false,\n    task_key: '',\n    message: 'Не передан параметр task_key',\n  },\n}"
      },
      "id": "error-fallback",
      "name": "Параметр не передан",
      "type": "n8n-nodes-base.code",
