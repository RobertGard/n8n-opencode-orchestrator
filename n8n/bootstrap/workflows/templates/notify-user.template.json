{
  "name": "Уведомление пользователя",
  "nodes": [
    {
      "parameters": {},
      "id": "trigger",
      "name": "Вызов уведомления",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        0,
        0
