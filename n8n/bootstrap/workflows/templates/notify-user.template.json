      "id": "tts-cleaner-agent",
      "name": "AI очистка текста",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -368,
        2368
      ]
    },
    {
      "parameters": {
        "jsCode": "// Извлекаем очищенный текст из ответа AI\nconst toText = (v) => String(v ?? '').trim()\n\nlet cleanText = ''\ntry {\n  cleanText = toText($('AI очистка текста').first().json.output ?? $('AI очистка текста').first().json.text ?? '')\n} catch (_) {}\n\n// Fallback: AI не ответил или ошибка — используем текст из входа\nif (!cleanText) {\n  const input = $input.first().json\n  cleanText = toText(input.text || (input.result || {}).text || '')\n}\n\n// Если всё ещё пусто — последний рубеж: текст из нормализации (содержит fallbackText)\nif (!cleanText) {\n  try {\n    cleanText = toText($('Нормализуем входные данные').first().json.text)\n  } catch (_) {}\n}\n\n// Финальная очистка\ncleanText = cleanText\n  .replace(/```[\\s\\S]*?```/g, '')\n  .replace(/`([^`]*)`/g, '$1')\n  .replace(/[*_~]{1,2}/g, '')\n  .replace(/\\[([^\\]]*)\\]\\([^)]*\\)/g, '$1')\n  .replace(/\\s+/g, ' ')\n  .trim()\n\nreturn { json: { cleanText } }"
      },
      "id": "extract-tts-text",
      "name": "Извлекаем очищенный текст",
      "type": "n8n-nodes-base.code",
