      ],
      "credentials": {
        "telegramApi": {
          "id": "__TELEGRAM_CREDENTIAL_ID__",
          "name": "__TELEGRAM_CREDENTIAL_NAME__"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Готовим текст для AI-очистки перед озвучиванием\n// Telegram API ответ может быть вложенным (result.text) или плоским (text)\nconst data = $input.first().json\nconst text = String(\n  data.text || (data.result || {}).text || $('Нормализуем входные данные').first().json.text || ''\n)\n\nreturn {\n  json: {\n    systemPrompt: `Ты — обработчик текста для озвучивания через TTS. Получив текст, верни ТОЛЬКО очищенный текст. ПРАВИЛА: 1. Если текст на английском — переведи на русский. 2. Убери пути к файлам, URL, куски кода, массивы, JSON, логи. 3. Убери markdown, бэктики, спецсимволы. 4. Сократи до 3-4 предложений, сохранив СУТЬ. 5. Не добавляй пояснений — только сам текст. 6. Plain text, без форматирования.`,\n    userPrompt: text,\n  },\n}"
      },
      "id": "prepare-tts-prompt",
      "name": "Готовим запрос для очистки текста",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -592,
        2368
      ]
    },
    {
      "parameters": {
        "options": {},
        "model": "deepseek-v4-pro"
      },
      "id": "ds-tts-model",
      "name": "DeepSeek Chat Model (TTS)",
      "type": "@n8n/n8n-nodes-langchain.lmChatDeepSeek",
      "typeVersion": 1,
      "position": [
        -288,
        2592
      ],
      "credentials": {
