      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "// Извлекаем sessionId из ответа OpenCode API (POST /session).\n// OpenCode может вернуть ответ в нескольких форматах, обрабатываем все.\n// Если сессия создана → sessionId есть, launchError пустой.\n// Если ошибка API    → launchError заполняется, sessionId пустой.\n// Если нет ни id ни ошибки → launchError = 'OpenCode не вернул session id.'\n\nconst stripHtml = (str) => String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').trim()\n\nconst sessionResponse = $input.item.json\nconst sessionId = String(\n  sessionResponse.sessionId || sessionResponse.id || sessionResponse.data?.id || ''\n).trim()\n\nconst launchError = sessionResponse.error\n  ? stripHtml(String(sessionResponse.error.message || sessionResponse.error))\n  : sessionId\n    ? ''\n    : 'OpenCode не вернул session id.'\n\nreturn {\n  json: { sessionId, launchError },\n}"
      },
      "id": "normalize-session",
      "name": "Нормализуем ответ",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
