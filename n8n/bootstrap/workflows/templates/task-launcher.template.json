        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "// Собираем итоговый результат запуска задачи в OpenCode.\n// Успех: launchError пустой, сессия запущена.\n// Ошибка HTTP: launchError = текст ошибки из ответа API.\n\nconst input = $('Разбираем входные данные').item.json\nlet launchError = input.launchError || ''\nconst promptError = $input.item.json.error\nif (promptError) launchError = String(promptError.message || promptError)\n\nreturn {\n  json: {\n    sessionId: input.sessionId,\n    launchError,\n    taskKey: input.taskKey,\n  },\n}"
      },
