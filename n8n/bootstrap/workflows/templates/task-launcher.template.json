    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "// Нормализуем входные данные от диспетчера и собираем тело запроса к OpenCode API.\n// Добавляем модель, если передана (формат provider/model → { providerID, modelID }).\n\nconst input = $('Запуск по вызову из другого сценария').item.json\n\nconst requestBody = {\n  prompt: String(input.promptText || '').trim(),\n  agent: String(input.opencodeAgent || '').trim(),\n  outputFormat: 'json',\n}\nif (input.opencodeModelProviderID) {\n  requestBody.model = {\n    id: '/',\n    name: String(input.opencodeModelModelID || '').trim(),\n    providerID: String(input.opencodeModelProviderID || '').trim(),\n  }\n}\n\nreturn {\n  json: {\n    taskKey: String(input.taskKey || '').trim(),\n    taskStatus: String(input.taskStatus || '').trim(),\n    claimToken: String(input.claimToken || '').trim(),\n    sessionId: String(input.sessionId || '').trim(),\n    promptAsyncPath: String(input.promptAsyncPath || '').trim(),\n    workerBaseUrl: String(input.workerBaseUrl || '').trim(),\n    authorizationHeader: String(input.authorizationHeader || '').trim(),\n    requestBody: JSON.stringify(requestBody),\n  },\n}"
      },
      "id": "parse-input",
      "name": "Разбираем входные данные",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
