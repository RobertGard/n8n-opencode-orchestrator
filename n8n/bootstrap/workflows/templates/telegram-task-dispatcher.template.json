      "id": "get-all-tasks",
      "name": "Получаем все задачи",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [
        700,
        320
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Готовим по одному пакету данных на каждого worker-а:\n// — список всех задач этого worker-а (отсортирован по queued_at)\n// — отдельно queued и active задачи с их количеством (для numeric-условий в IF-нодах)\n// — все endpoint-ы OpenCode из routing-конфигурации\n// — модель OpenCode (разбираем из формата \"provider/model\", например \"deepseek/deepseek-v4-pro\")\n\nconst routing = $('Задаём конфигурацию OpenCode').first().json\nconst allTasks = $('Получаем все задачи').all().map((item) => item.json)\n\n// Сортировка задач: более ранние (queued_at меньше) — выше\nfunction sortByQueuedAt(left, right) {\n  return String(left.queued_at || '').localeCompare(String(right.queued_at || ''))\n}\n\n// Разбор строки \"provider/model\" → { providerID, modelID }\n// Возвращает null если формат невалидный (пусто, нет /, / в начале или конце)\nfunction parseModel(modelRef) {\n  const normalized = String(modelRef || '').trim()\n  const separatorIndex = normalized.indexOf('/')\n\n  if (!normalized || separatorIndex <= 0 || separatorIndex === normalized.length - 1) {\n    return null\n  }\n\n  return {\n    providerID: normalized.slice(0, separatorIndex),\n    modelID: normalized.slice(separatorIndex + 1),\n  }\n}\n\nreturn Object.entries(routing.workers || {}).map(([workerAlias, workerConfig]) => {\n  const workerTasks = allTasks\n    .filter((task) => String(task.worker_alias || '').trim() === workerAlias)\n    .sort(sortByQueuedAt)\n\n  const queuedTasks = workerTasks.filter((task) => String(task.status || '').trim() === 'queued')\n  const activeTasks = workerTasks.filter((task) =>\n    ['running', 'needs_input'].includes(String(task.status || '').trim())\n  )\n\n  return {\n    json: {\n      workerAlias,\n      workerBaseUrl: String(workerConfig.baseUrl || '').trim(),\n      authorizationHeader: String(workerConfig.authorizationHeader || '').trim(),\n      sessionCreatePath: String(routing.endpoints?.sessionCreate || '').trim(),\n      messageListPath: String(routing.endpoints?.messageList || '').trim(),\n      questionListPath: String(routing.endpoints?.questionList || '').trim(),\n      questionReplyPath: String(routing.endpoints?.questionReply || '').trim(),\n      questionRejectPath: String(routing.endpoints?.questionReject || '').trim(),\n      permissionListPath: String(routing.endpoints?.permissionList || '').trim(),\n      permissionReplyPath: String(routing.endpoints?.permissionReply || '').trim(),\n      sessionStatusPath: String(routing.endpoints?.sessionStatus || '').trim(),\n      promptAsyncPath: String(routing.endpoints?.promptAsync || '').trim(),\n      opencodeAgent: String(routing.defaultAgent || 'build').trim(),\n      opencodeModel: parseModel(routing.defaultModel),\n      workerTasks,\n      queuedTasks,\n      queuedTasksCount: queuedTasks.length,\n      activeTasks,\n      activeTasksCount: activeTasks.length,\n    },\n  }\n})"
      },
      "id": "prepare-workers",
      "name": "Готовим пакеты обработчиков",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        940,
