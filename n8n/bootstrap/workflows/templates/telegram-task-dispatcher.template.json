    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "// Приводим к единому виду как первый ответ OpenCode, так и ответы после уточнений.\n// Если на входе есть error, фиксируем failed. Иначе извлекаем текстовые части и варианты ответа.\nconst task = $('Выбираем кандидатную задачу').item.json.task\nlet response\n\ntry {\n  response = $('Отправляем ответ в OpenCode').item.json\n} catch {\n  response = $('Отправляем задачу в OpenCode').item.json\n}\n\nif (response.error) {\n  return {\n    json: {\n      resultStatus: 'failed',\n      optionsCount: 0,\n      questionText: '',\n      optionsJson: '[]',\n      replyText: `Задача ${task.task_key} завершилась ошибкой OpenCode: ${String(response.error.message || response.error)}`,\n    },\n  }\n}\n\nconst textParts = Array.isArray(response.parts)\n  ? response.parts\n      .filter((part) => String(part.type || '') === 'text')\n      .map((part) => String(part.content || part.text || '').trim())\n      .filter(Boolean)\n  : []\n\nconst rawText = textParts.join('\\n').trim() || JSON.stringify(response)\nconst lines = rawText.split(/\\r?\\n/).map((line) => line.trim()).filter(Boolean)\nconst optionRegex = /^(?:\\d+[\\.\\)]|[-*•])\\s+(.+)$/\nconst options = lines\n  .map((line) => {\n    const match = line.match(optionRegex)\n    return match ? match[1].trim() : null\n  })\n  .filter(Boolean)\n  .map((value) => ({ label: value, value }))\n\nif (options.length > 0) {\n  const optionsText = options.map((option, index) => `${index + 1}. ${option.label}`).join('\\n')\n  return {\n    json: {\n      resultStatus: 'needs_input',\n      optionsCount: options.length,\n      questionText: `${rawText}\\n\\nВарианты ответа:\\n${optionsText}`.trim(),\n      optionsJson: JSON.stringify(options),\n      replyText: rawText,\n    },\n  }\n}\n\nreturn {\n  json: {\n    resultStatus: 'done',\n    optionsCount: 0,\n    questionText: '',\n    optionsJson: '[]',\n    replyText: `Задача ${task.task_key} завершена.\\n\\n${rawText}`,\n  },\n}"
      },
