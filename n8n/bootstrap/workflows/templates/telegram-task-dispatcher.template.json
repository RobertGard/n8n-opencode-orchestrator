          "conditions": [
            {
              "leftValue": "={{ $('Готовим пакеты обработчиков').item.json.queuedTasksCount }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            },
            {
              "leftValue": "={{ $('Готовим пакеты обработчиков').item.json.activeTasksCount }}",
              "rightValue": 0,
              "operator": {
