        "language": "javaScript",
        "jsCode": "// Нормализуем ответ от OpenCode после создания сессии.\n// Здесь оставляем только данные, которые нужны для проверки запуска.\nconst sessionResponse = $('Создаём сессию OpenCode').item.json\n\nconst sessionId = String(sessionResponse.id || sessionResponse.data?.id || sessionResponse.sessionId || '').trim()\nconst launchError = sessionResponse.error\n  ? String(sessionResponse.error.message || sessionResponse.error)\n  : sessionId\n    ? ''\n    : 'OpenCode не вернул session id.'\n\nreturn {\n  json: {\n    sessionId,\n    launchError,\n    messageUrl: sessionId\n      ? $('Готовим пакеты worker-ов').item.json.workerBaseUrl + $('Готовим пакеты worker-ов').item.json.sessionMessagePath.replace(':id', sessionId)\n      : '',\n  },\n}"
      },
