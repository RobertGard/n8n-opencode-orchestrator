        "jsCode": "// Преобразуем ответ пользователя к тексту, который ожидает OpenCode.\n// Если пользователь отправил номер варианта, подставляем реальное значение из сохранённых options.\nconst options = JSON.parse(String($('Разбираем ответ OpenCode').item.json.optionsJson || '[]'))\nconst answerRaw = String($('Запрашиваем ответ в Telegram').item.json.data?.text || '').trim()\nlet answerText = answerRaw\n\nif (/^\\d+$/.test(answerRaw)) {\n  const selected = options[Number(answerRaw) - 1]\n  if (selected) answerText = String(selected.value || selected.label || answerRaw)\n}\n\nreturn {\n  json: {\n    answerText,\n  },\n}"
