{
  "id": "900010",
  "name": "Telegram Task Ingress",
  "nodes": [
    {
      "parameters": {
        "updates": [
          "message"
        ],
        "additionalFields": {}
      },
      "id": "telegram-trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.2,
      "position": [260, 300],
      "credentials": {
        "telegramApi": {
          "id": "__TELEGRAM_CREDENTIAL_ID__",
          "name": "__TELEGRAM_CREDENTIAL_NAME__"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const input = $json\nconst msg = input.message || {}\nconst text = String(msg.text || '').trim()\nconst chatId = String(msg.chat?.id || '')\nconst userId = String(msg.from?.id || '')\nconst username = String(msg.from?.username || msg.from?.first_name || '')\nconst allowedChatId = String(process.env.TELEGRAM_CHAT_ID || '').trim()\nconst chatAllowed = Boolean(allowedChatId) && chatId === allowedChatId\n\nif (!text) return [{ chatAllowed, skip: true, chatId, replyText: 'Пустое сообщение не поставлено в очередь.' }]\n\nfunction parseFlags(inputText) {\n  const flags = {}\n  const regex = /--([a-zA-Z0-9_-]+)=\"([^\"]*)\"|--([a-zA-Z0-9_-]+)='([^']*)'/g\n  let match\n  while ((match = regex.exec(inputText)) !== null) {\n    const key = match[1] || match[3]\n    const value = match[2] ?? match[4] ?? ''\n    flags[key] = value\n  }\n  return flags\n}\n\nlet workerAlias = 'primary'\nlet mode = 'prompt'\nlet commandName = ''\nlet prompt = ''\n\nif (text.startsWith('/task')) {\n  const rest = text.replace(/^\/task\\s*/, '')\n  const flags = parseFlags(rest)\n  workerAlias = flags.worker || 'primary'\n  prompt = flags.prompt || ''\n  if (!prompt) {\n    return [{ chatAllowed, skip: true, chatId, replyText: 'Для /task укажи задачу. Пример: /task --worker=\"primary\" --prompt=\"Почини CI\"' }]\n  }\n} else if (text.startsWith('/command')) {\n  mode = 'command'\n  const rest = text.replace(/^\/command\\s*/, '')\n  const flags = parseFlags(rest)\n  workerAlias = flags.worker || 'primary'\n  commandName = flags.name || flags.command || 'verify'\n} else if (text.startsWith('/help')) {\n  return [{ chatAllowed, skip: true, chatId, replyText: 'Команды:\n/task --worker=\"primary\" --prompt=\"текст задачи\"\n/command --worker=\"primary\" --name=\"verify\"\nИспользуй значения в кавычках.' }]\n} else {\n  prompt = text\n}\n\nconst taskKey = `${Date.now()}-${chatId}-${Math.random().toString(36).slice(2, 8)}`\nreturn [{ chatAllowed, skip: false, taskKey, chatId, userId, username, workerAlias, mode, commandName, prompt, contextJson: JSON.stringify([]), queuedAt: new Date().toISOString(), replyText: `Задача поставлена в очередь для worker: ${workerAlias}` }]"
      },
      "id": "parse-command",
      "name": "Parse Telegram Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [520, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "leftValue": "={{$json.chatAllowed}}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-chat-allowed",
      "name": "Chat Allowed?",
