{
  // Репозитории для авто-клонирования
  "repos": [
    {
      "slug": "example-project",
      "url": "https://github.com/example/example-project.git",
      "ref": "main",
      "path": "example-project",
      "package_manager": "auto",
      "turbo_smoke": false,
      "turbo_tasks": ["build", "test"],
      "auto_start_docker": true
    }
  ],

  "tooling": {
    // npm install -g. mcp = зарегистрировать как MCP-сервер в OpenCode
    "npm": [
      { "package": "@opengsd/gsd-core@latest", "binary": "gsd-core", "args": "--opencode --global" },
      { "package": "@modelcontextprotocol/server-filesystem", "mcp": { "name": "filesystem", "args": ["/workspace"], "enabled": true } },
      { "package": "@modelcontextprotocol/server-github", "mcp": { "name": "github", "enabled": true } },
      { "package": "@modelcontextprotocol/server-memory", "mcp": { "name": "memory", "enabled": true } },
      { "package": "@upstash/context7-mcp", "mcp": { "name": "context7", "type": "remote", "url": "https://mcp.context7.com/mcp", "enabled": true } },
      { "package": "@modelcontextprotocol/server-brave-search", "mcp": { "name": "brave-search", "enabled": true } },
      { "package": "@modelcontextprotocol/server-sequential-thinking", "mcp": { "name": "sequential-thinking", "enabled": true } },
      { "package": "@playwright/mcp", "mcp": { "name": "playwright", "enabled": true } },
      { "package": "@modelcontextprotocol/server-postgres", "mcp": { "name": "postgres", "args": ["{env:DATABASE_URL}"], "enabled": true } }
    ],

    // uv tool install. mcp = зарегистрировать как MCP-сервер в OpenCode
    "uv": [
      { "package": "serena-agent@latest", "python": "3.13", "args": "--prerelease=allow", "mcp": { "name": "serena", "command": ["serena", "start-mcp-server", "--context", "ide", "--project-from-cwd"], "enabled": true } },
      { "package": "browser-use", "python": "3.13" }
    ],

    // после установки всех пакетов
    "post_install": [
      "serena init",
      "npx playwright install chromium"
    ]
  }
}
